<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido/a, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
        {{/username}}
        {{^username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido/a!</p>
        {{/username}}

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-blue-700 mb-3">Tu Perfil</h2>
                <p class="text-gray-600 mb-4">Gestiona la información de tu cuenta.</p>
                <a href="/profile" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Perfil</a>
            </div>
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 mb-3">Configuraciones</h2>
                <p class="text-gray-600 mb-4">Ajusta las preferencias de tu aplicación.</p>
                <a href="/settings" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Configuración</a>
            </div>
            <div class="bg-yellow-50 border border-yellow-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-yellow-700 mb-3">Gestionar Usuarios</h2>
                <p class="text-gray-600 mb-4">Crea administradores, profesores y estudiantes</p>
                <a href="/gestionUsuario" class="inline-block bg-yellow-600 text-white py-2 px-4 rounded-md hover:bg-yellow-700 transition duration-300">Registrar usuarios</a>
            </div>
            <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 mb-3">Gestión de Carreras</h2>
                <p class="text-gray-600 mb-4">Crea carreras y asígnale sus respectivos planes y materias.</p>
                <a href="/crearCarrera" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Gestionar carreras</a>
            </div>
            <div class="bg-rose-50 border border-rose-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-rose-700 mb-3">Vincular Profesores</h2>
                <p class="text-gray-600 mb-4">Vincula profesores a materias y cátedras.</p>
                <a href="/vincularProfesores" class="inline-block bg-rose-600 text-white py-2 px-4 rounded-md hover:bg-rose-700 transition duration-300">Vincular profesores</a>
            </div>
            <div class="bg-rose-50 border border-rose-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-rose-700 mb-3">Ver Reporte de Riesgo</h2>
                <p class="text-gray-600 mb-4">JEJIJO DE JU.</p>
                <a href="/reporteRiesgo" class="inline-block bg-rose-600 text-white py-2 px-4 rounded-md hover:bg-rose-700 transition duration-300">Ver Reporte</a>
            </div>
        </div>
        <div class="w-full flex justify-center mt-6">
            <a href="/logout"
            class="bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">
                Cerrar Sesión
            </a>
        </div>
    </div>
</body>
</html>